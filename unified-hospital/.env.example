# ==========================================
# Shalamar Hospital — Environment Variables
# Copy this to .env and fill in your values
# ==========================================

# Server
PORT=5000

# MySQL Database (Railway will provide these automatically when you add a MySQL plugin)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=shalamar_hospital
DB_PORT=3306

# JWT Secret — change this to a long random string in production!
JWT_SECRET=shalamar_hospital_secret_key_2026_change_this_in_production

# OpenAI API Key — required for MediAI chat feature
OPENAI_API_KEY=sk-your-openai-api-key-here
