# ==========================================
# Shalamar Hospital Backend Configuration
# ==========================================

# Server Port (the port your backend will run on)
PORT=5000

# Database Configuration (MySQL)
# If using XAMPP/WAMP locally: host=localhost, user=root, password=""
# If using a cloud database (Railway/PlanetScale): use the provided connection details
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=shalamar_hospital
DB_PORT=3306

# JWT Secret Key (for authentication tokens)
# Generate a strong random string for production
JWT_SECRET=shalamar_hospital_secret_key_2026_change_this_in_production

# Frontend URL (for CORS - allowing frontend to connect)
# In development:
FRONTEND_URL=http://localhost:3000
# In production (example):
# FRONTEND_URL=https://yourdomain.com
